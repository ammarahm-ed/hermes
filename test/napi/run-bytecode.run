// REQUIRES: napi

// Test that napi-runner can execute pre-compiled bytecode via hermes_run_bytecode.

// Numeric expression.
// RUN: echo '1 + 2' > %t.js && %hermesc -emit-binary -out %t.hbc %t.js
// RUN: %napi-runner %t.hbc | %FileCheck --match-full-lines --check-prefix=NUM %s
// NUM: 3

// String expression.
// RUN: echo "'foo' + 'bar'" > %t.js && %hermesc -emit-binary -out %t.hbc %t.js
// RUN: %napi-runner %t.hbc | %FileCheck --match-full-lines --check-prefix=STR %s
// STR: foobar

// Undefined result (no output).
// RUN: echo 'var x = 1' > %t.js && %hermesc -emit-binary -out %t.hbc %t.js
// RUN: %napi-runner %t.hbc | %FileCheck --allow-empty --check-prefix=UNDEF %s
// UNDEF-NOT: {{.}}

// JS source mode still works.
// RUN: echo '7 * 6' > %t.js
// RUN: %napi-runner %t.js | %FileCheck --match-full-lines --check-prefix=SRC %s
// SRC: 42

// Runtime error in bytecode.
// RUN: echo "throw new Error('boom')" > %t.js && %hermesc -emit-binary -out %t.hbc %t.js
// RUN: ! %napi-runner %t.hbc 2>&1 | %FileCheck --check-prefix=ERR %s
// ERR: Error: boom

// Invalid bytecode.
// RUN: echo 'garbage' > %t.bad.hbc
// RUN: ! %napi-runner %t.bad.hbc 2>&1 | %FileCheck --check-prefix=BAD %s
// BAD: Error:
